{
  "$schema": "https://getcomposer.org/schema.json",
  "name": "asterodigital/astero",
  "version": "1.0.50",
  "type": "project",
  "description": "Astero is an all-in-one, white-label website building platform designed for digital agencies and developers. It provides a complete toolkit to create, manage, and scale client websites under their own brand—without complex maintenance or DevOps overhead.",
  "keywords": [
    "astero",
    "cms",
    "saas",
    "laravel",
    "tailwindcss",
    "inertia",
    "react",
    "twig",
    "api"
  ],
  "license": "proprietary",
  "require": {
    "php": "^8.4",
    "chillerlan/php-qrcode": "^6.0.0",
    "geoip2/geoip2": "^3.3",
    "inertiajs/inertia-laravel": "^3.0.0-beta5",
    "laravel/ai": "^0.3.2",
    "laravel/cashier": "^16.5.0",
    "laravel/framework": "^13.2.0",
    "laravel/socialite": "^5.26.0",
    "league/flysystem-aws-s3-v3": "^3.32.0",
    "league/flysystem-ftp": "^3.31",
    "opcodesio/log-viewer": "^3.24.0",
    "phpseclib/phpseclib": "^3.0.50",
    "spatie/laravel-activitylog": "^5.0.0",
    "spatie/laravel-medialibrary": "^11.21.0",
    "spatie/laravel-permission": "^7.2.4",
    "tightenco/ziggy": "^2.6.2",
    "twig/twig": "^3.24.0"
  },
  "require-dev": {
    "driftingly/rector-laravel": "^2.2.0",
    "fakerphp/faker": "^1.24.1",
    "fruitcake/laravel-debugbar": "^4.1.3",
    "larastan/larastan": "^3.9.3",
    "laravel/boost": "^2.4.0",
    "laravel/pail": "^1.2.6",
    "laravel/pint": "^1.29.0",
    "laravel/sail": "^1.55.0",
    "laravel/tinker": "^3.0.0",
    "mockery/mockery": "^1.6.12",
    "nunomaduro/collision": "^8.9.1",
    "phpunit/phpunit": "^13.0.5",
    "rector/rector": "^2.3.9"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "setup": [
      "composer install",
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
      "@php artisan key:generate",
      "@php artisan migrate --force",
      "pnpm install",
      "pnpm build"
    ],
    "dev": [
      "Composer\\Config::disableProcessTimeout",
      "pnpm exec concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"pnpm dev\" --names=server,queue,logs,vite --kill-others"
    ],
    "lint": [
      "pint --parallel app bootstrap config database routes tests modules"
    ],
    "lint:check": [
      "pint --parallel --test app bootstrap config database routes tests modules"
    ],
    "analyse": [
      "@php vendor/bin/phpstan analyse --memory-limit=1G"
    ],
    "rector": [
      "@php vendor/bin/rector process"
    ],
    "rector:dry": [
      "@php vendor/bin/rector process --dry-run"
    ],
    "quality:check": [
      "Composer\\Config::disableProcessTimeout",
      "@lint:check",
      "@analyse",
      "pnpm lint:check",
      "pnpm format:check",
      "pnpm types:check",
      "@php artisan test:guard --ansi",
      "@php artisan config:clear --ansi",
      "@php artisan test"
    ],
    "ci:check": [
      "Composer\\Config::disableProcessTimeout",
      "pnpm lint:check",
      "pnpm format:check",
      "pnpm types:check",
      "@test"
    ],
    "test": [
      "@php artisan test:guard --ansi",
      "@php artisan config:clear --ansi",
      "@lint:check",
      "@php artisan test"
    ],
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi"
    ],
    "post-update-cmd": [
      "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
    ],
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ],
    "post-create-project-cmd": [
      "@php artisan key:generate --ansi",
      "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
      "@php artisan migrate --graceful --ansi"
    ],
    "pre-package-uninstall": [
      "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
    ]
  },
  "extra": {
    "laravel": {
      "dont-discover": []
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "php-http/discovery": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
