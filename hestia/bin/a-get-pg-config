#!/bin/bash
#
# Script: a-get-pg-config
#
# Description: Returns current PostgreSQL configuration settings and system
#              hardware info for optimization recommendations.
#
# Usage: a-get-pg-config
#
# Output (JSON):
# {
#   "ram_mb": 16384,
#   "cpu_cores": 4,
#   "pg_version": "18.1",
#   "settings": {
#     "shared_buffers": "128MB",
#     "effective_cache_size": "4GB",
#     "work_mem": "4MB",
#     "maintenance_work_mem": "64MB",
#     "wal_buffers": "-1",
#     "max_connections": "100",
#     "random_page_cost": "4",
#     "effective_io_concurrency": "1",
#     "max_worker_processes": "8",
#     "max_parallel_workers_per_gather": "2",
#     "max_parallel_workers": "8",
#     "max_parallel_maintenance_workers": "2",
#     "huge_pages": "try",
#     "min_wal_size": "80MB",
#     "max_wal_size": "1GB",
#     "checkpoint_completion_target": "0.9",
#     "default_statistics_target": "100",
#     "log_min_duration_statement": "-1"
#   }
# }
#
# Exit Codes:
#   0 - Success
#   1 - PostgreSQL not found or not running

# --- Configuration ---
HESTIA=${HESTIA:-/usr/local/hestia}

# --- Functions ---

get_ram_mb() {
    if [ -f /proc/meminfo ]; then
        grep MemTotal /proc/meminfo | awk '{print int($2/1024)}'
    else
        echo "0"
    fi
}

get_cpu_cores() {
    if [ -f /proc/cpuinfo ]; then
        grep -c '^processor' /proc/cpuinfo
    else
        echo "1"
    fi
}

get_pg_version() {
    # Try psql first
    if command -v psql &>/dev/null; then
        psql --version 2>/dev/null | awk '{print $3}' | head -1
        return
    fi

    # Try pg_config
    if command -v pg_config &>/dev/null; then
        pg_config --version 2>/dev/null | awk '{print $2}'
        return
    fi

    echo ""
}

get_pg_setting() {
    local setting_name="$1"
    sudo -u postgres psql -t -A -c "SHOW ${setting_name};" 2>/dev/null | tr -d ' '
}

# --- Main Logic ---

# Check if PostgreSQL is available
if ! command -v psql &>/dev/null; then
    echo '{"error": "PostgreSQL client (psql) not found"}'
    exit 1
fi

# Check if PostgreSQL is running
if ! sudo -u postgres psql -c "SELECT 1;" &>/dev/null; then
    echo '{"error": "PostgreSQL is not running or not accessible"}'
    exit 1
fi

# Collect system info
ram_mb=$(get_ram_mb)
cpu_cores=$(get_cpu_cores)
pg_version=$(get_pg_version)

# Collect PostgreSQL settings
shared_buffers=$(get_pg_setting "shared_buffers")
effective_cache_size=$(get_pg_setting "effective_cache_size")
work_mem=$(get_pg_setting "work_mem")
maintenance_work_mem=$(get_pg_setting "maintenance_work_mem")
wal_buffers=$(get_pg_setting "wal_buffers")
max_connections=$(get_pg_setting "max_connections")
random_page_cost=$(get_pg_setting "random_page_cost")
effective_io_concurrency=$(get_pg_setting "effective_io_concurrency")
max_worker_processes=$(get_pg_setting "max_worker_processes")
max_parallel_workers_per_gather=$(get_pg_setting "max_parallel_workers_per_gather")
max_parallel_workers=$(get_pg_setting "max_parallel_workers")
max_parallel_maintenance_workers=$(get_pg_setting "max_parallel_maintenance_workers")
huge_pages=$(get_pg_setting "huge_pages")
min_wal_size=$(get_pg_setting "min_wal_size")
max_wal_size=$(get_pg_setting "max_wal_size")
checkpoint_completion_target=$(get_pg_setting "checkpoint_completion_target")
default_statistics_target=$(get_pg_setting "default_statistics_target")
log_min_duration_statement=$(get_pg_setting "log_min_duration_statement")
wal_compression=$(get_pg_setting "wal_compression")
wal_log_hints=$(get_pg_setting "wal_log_hints")
checkpoint_timeout=$(get_pg_setting "checkpoint_timeout")
log_checkpoints=$(get_pg_setting "log_checkpoints")
log_temp_files=$(get_pg_setting "log_temp_files")
log_lock_waits=$(get_pg_setting "log_lock_waits")
idle_in_transaction_session_timeout=$(get_pg_setting "idle_in_transaction_session_timeout")
shared_preload_libraries=$(get_pg_setting "shared_preload_libraries")

cat << EOF
{
  "ram_mb": ${ram_mb:-0},
  "cpu_cores": ${cpu_cores:-1},
  "pg_version": "${pg_version}",
  "settings": {
    "shared_buffers": "${shared_buffers}",
    "effective_cache_size": "${effective_cache_size}",
    "work_mem": "${work_mem}",
    "maintenance_work_mem": "${maintenance_work_mem}",
    "wal_buffers": "${wal_buffers}",
    "max_connections": "${max_connections}",
    "random_page_cost": "${random_page_cost}",
    "effective_io_concurrency": "${effective_io_concurrency}",
    "max_worker_processes": "${max_worker_processes}",
    "max_parallel_workers_per_gather": "${max_parallel_workers_per_gather}",
    "max_parallel_workers": "${max_parallel_workers}",
    "max_parallel_maintenance_workers": "${max_parallel_maintenance_workers}",
    "huge_pages": "${huge_pages}",
    "min_wal_size": "${min_wal_size}",
    "max_wal_size": "${max_wal_size}",
    "checkpoint_completion_target": "${checkpoint_completion_target}",
    "default_statistics_target": "${default_statistics_target}",
    "log_min_duration_statement": "${log_min_duration_statement}",
    "wal_compression": "${wal_compression}",
    "wal_log_hints": "${wal_log_hints}",
    "checkpoint_timeout": "${checkpoint_timeout}",
    "log_checkpoints": "${log_checkpoints}",
    "log_temp_files": "${log_temp_files}",
    "log_lock_waits": "${log_lock_waits}",
    "idle_in_transaction_session_timeout": "${idle_in_transaction_session_timeout}",
    "shared_preload_libraries": "${shared_preload_libraries}"
  }
}
EOF

exit 0
