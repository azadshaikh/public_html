#!/bin/bash
#
# Script: a-sync-releases
#
# Description: Syncs application releases from central API to local repository.
#              Downloads new versions and optionally sets them as active.
#
# Usage: a-sync-releases TYPE PACKAGE_ID [VERSION] [--set-active] [--insecure]
#
# Exit Codes:
#   0   - Success
#   1   - Invalid arguments
#   207 - Required dependency missing
#   208 - API connection failed
#   209 - Failed to parse API response
#   210 - Directory operation failed
#   211 - Download failed

# --- Configuration ---
HESTIA=${HESTIA:-/usr/local/hestia}
BIN=${BIN:-/usr/local/hestia/bin}
ASTERO_DATA_DIR="${ASTERO_DATA_DIR:-/usr/local/hestia/data/astero}"
RELEASES_DIR="$ASTERO_DATA_DIR/releases"
LOG_FILE="${ASTERO_DATA_DIR}/logs/astero-scripts.log"

# Source shared Astero functions
[ -f "$BIN/a-common.sh" ] && source "$BIN/a-common.sh"

# Source Astero config (provides RELEASE_API_URL, MAX_RETRIES, API_TIMEOUT)
[ -f "$BIN/a-config.sh" ] && source "$BIN/a-config.sh"
API_BASE_URL="${RELEASE_API_URL}"
RETRY_COUNT="${MAX_RETRIES:-3}"

# Source Hestia core functions
source $HESTIA/func/main.sh
source $HESTIA/conf/hestia.conf

# --- Helper Functions ---
log_error() {
    local msg="$1"
    mkdir -p "$(dirname "$LOG_FILE")"
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] [a-sync-releases] ERROR: $msg" >> "$LOG_FILE"
    echo "Error: $msg" >&2
}

handle_error() {
    log_error "$2"
    exit "$1"
}

show_usage() {
    echo "Usage: a-sync-releases TYPE PACKAGE_ID [VERSION] [--set-active] [--insecure]"
    exit 1
}

# --- Argument Validation ---
for cmd in curl jq wget; do
    command -v "$cmd" &>/dev/null || handle_error 207 "Required dependency '$cmd' is not installed."
done

[ $# -lt 2 ] && show_usage

release_type=$1
package_id=$2
target_version=""
set_active=false
tls_insecure=false

shift 2
while [ $# -gt 0 ]; do
    case "$1" in
        --set-active) set_active=true ;;
        --insecure) tls_insecure=true ;;
        *) [ -z "$target_version" ] && target_version=$1 ;;
    esac
    shift
done

if [ "$tls_insecure" = false ] && [ -f "$ASTERO_DATA_DIR/release_api_insecure" ]; then
    insecure_value=$(tr -d '\n' < "$ASTERO_DATA_DIR/release_api_insecure")
    if [ "$insecure_value" = "1" ]; then
        tls_insecure=true
    fi
fi

echo "Syncing $release_type/$package_id..."

# --- API Request ---
API_URL="$API_BASE_URL/latest-update/$release_type/$package_id"
release_api_key="$(get_release_api_key)"
[ -z "$release_api_key" ] && handle_error 208 "Release API key is not configured. Set RELEASE_API_KEY or create $ASTERO_DATA_DIR/release_api_key."

api_response_file=$(mktemp)
api_error_file=$(mktemp)
cleanup_api_temp_files() {
    rm -f "$api_response_file" "$api_error_file"
}
trap cleanup_api_temp_files EXIT

curl_args=(-sS -L --connect-timeout 10 --max-time "${API_TIMEOUT:-60}" --retry "$RETRY_COUNT" --retry-delay 2 --retry-connrefused -H "Accept: application/json" -H "X-Release-Key: $release_api_key" -o "$api_response_file" -w "%{http_code}")
if [ "$tls_insecure" = true ]; then
    curl_args+=(-k)
fi

http_status=$(curl "${curl_args[@]}" "$API_URL" 2>"$api_error_file")
curl_exit=$?

if [ $curl_exit -ne 0 ]; then
    curl_error="$(tail -n 1 "$api_error_file" 2>/dev/null)"
    [ -z "$curl_error" ] && curl_error="unknown curl error"
    handle_error 208 "API request failed (curl exit $curl_exit) at $API_URL: $curl_error"
fi

json_response="$(cat "$api_response_file" 2>/dev/null)"
[ -z "$http_status" ] && http_status="000"

if ! [[ "$http_status" =~ ^2[0-9][0-9]$ ]]; then
    api_message="$(echo "$json_response" | jq -r '.message // empty' 2>/dev/null)"
    [ -z "$api_message" ] && api_message="$(echo "$json_response" | tr '\n' ' ' | head -c 300)"
    [ -z "$api_message" ] && api_message="Unexpected HTTP response with empty body"
    handle_error 208 "API HTTP $http_status at $API_URL: $api_message"
fi

echo "$json_response" | jq -e . >/dev/null 2>&1 || handle_error 209 "API returned invalid JSON response."

api_status=$(echo "$json_response" | jq -r '.status // empty')
if [ "$api_status" = "error" ]; then
    api_message="$(echo "$json_response" | jq -r '.message // empty')"
    if echo "$api_message" | grep -qi '^No update found'; then
        echo "No update found for $release_type/$package_id. Skipping sync."
        exit 0
    fi
    handle_error 209 "API error: $api_message"
fi

app_version=$(echo "$json_response" | jq -r '.version')
download_link=$(echo "$json_response" | jq -r '.download_link')
version_type=$(echo "$json_response" | jq -r '.version_type // "stable"')

[ -z "$app_version" ] || [ "$app_version" = "null" ] && handle_error 209 "Failed to parse version from API."
[ -z "$download_link" ] || [ "$download_link" = "null" ] && handle_error 209 "Failed to parse download link from API."

echo "Latest version: v$app_version"

# --- Local Repository Setup ---
PACKAGE_DIR="$RELEASES_DIR/$release_type/$package_id"
VERSION_FILE="$PACKAGE_DIR/v$app_version.zip"

mkdir -p "$PACKAGE_DIR" || handle_error 210 "Failed to create package directory."

# Check if already exists
if [ -f "$VERSION_FILE" ]; then
    echo "Version v$app_version already exists locally"
    [ "$set_active" = true ] && ln -sfn "v$app_version.zip" "$PACKAGE_DIR/current" && echo "Set as active"
    exit 0
fi

# --- Download with Retry ---
echo "Downloading v$app_version..."

download_success=false
for attempt in $(seq 1 "$RETRY_COUNT"); do
    if [ "$attempt" -gt 1 ]; then
        echo "Retry attempt $attempt of $RETRY_COUNT..."
        sleep 2
    fi

    wget_args=(-q --timeout="${API_TIMEOUT:-60}" -O "$VERSION_FILE")
    if [ "$tls_insecure" = true ]; then
        wget_args+=(--no-check-certificate)
    fi

    wget "${wget_args[@]}" "$download_link"
    wget_exit=$?

    if [ $wget_exit -eq 0 ] && [ -s "$VERSION_FILE" ]; then
        download_success=true
        break
    fi

    # Clean up failed download
    rm -f "$VERSION_FILE"
done

if [ "$download_success" = false ]; then
    handle_error 211 "Download failed after $RETRY_COUNT attempts."
fi

file_size=$(stat -c%s "$VERSION_FILE" 2>/dev/null || echo "unknown")
echo "Downloaded: v$app_version.zip ($file_size bytes)"

# --- Auto-create Master Installation ---
# Masters are shared read-only across all websites to save storage
if [ -x "$BIN/a-install-master" ]; then
    echo "Creating master installation for v$app_version..."
    "$BIN/a-install-master" "$app_version" "$release_type" "$package_id"
    if [ $? -eq 0 ]; then
        echo "Master installation created successfully"
    else
        echo "Warning: Failed to create master installation (websites will create on demand)"
    fi
fi

# --- Update Metadata ---
METADATA_FILE="$ASTERO_DATA_DIR/releases.json"
if [ -f "$METADATA_FILE" ]; then
    tmp_file=$(mktemp)
    jq --arg type "$release_type" --arg pkg "$package_id" --arg ver "$app_version" \
       --arg vtype "$version_type" --arg date "$(date -Iseconds)" \
       '.[$type + "/" + $pkg + "/v" + $ver] = {"release_type": $type, "package_id": $pkg, "version": $ver, "version_type": $vtype, "synced_at": $date}' \
       "$METADATA_FILE" > "$tmp_file" && mv "$tmp_file" "$METADATA_FILE"
else
    jq -n --arg type "$release_type" --arg pkg "$package_id" --arg ver "$app_version" \
          --arg vtype "$version_type" --arg date "$(date -Iseconds)" \
          '{($type + "/" + $pkg + "/v" + $ver): {"release_type": $type, "package_id": $pkg, "version": $ver, "version_type": $vtype, "synced_at": $date}}' > "$METADATA_FILE"
fi

# Set active if requested
[ "$set_active" = true ] && ln -sfn "v$app_version.zip" "$PACKAGE_DIR/current" && echo "Set as active"

echo "Synced: $release_type/$package_id v$app_version"

# --- Auto-update GeoIP Database ---
# Updates MaxMind GeoLite2 database (license key is hardcoded in script)
if [ -x "$BIN/a-update-geoip" ]; then
    echo ""
    echo "Checking GeoIP database update..."
    if "$BIN/a-update-geoip" --force 2>/dev/null; then
        echo "GeoIP database updated"
    else
        echo "GeoIP update skipped or failed (non-fatal)"
    fi
fi

$BIN/v-log-action "system" "Info" "Astero" "Release synced: $release_type/$package_id v$app_version"
exit 0
