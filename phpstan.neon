includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/nesbot/carbon/extension.neon

parameters:
    level: 5

    paths:
        - app/
        - bootstrap/app.php
        - config/
        - database/
        - modules/
        - routes/
        - tests/

    excludePaths:
        - bootstrap/cache/
        - storage/
        - vendor/

    tmpDir: storage/framework/cache/phpstan
