{% extends 'layouts/layout.twig' %}

{% block body_class %}home homepage{% endblock %}

{% block content %}
    {% if session_has('success') or session_has('error') %}
        {{ form_response() }}
    {% endif %}

    <div class="col-12">
        {% if page is defined and page is not null %}
            <div class="container-wrapper page-content" data-v-post-content data-astero-enabled>
                {% if page.format == 'asterobuilder' and page.content %}
                    {{ page.content|raw }}
                {% elseif page.content %}
                    {{ page.content|raw }}
                {% else %}
                    <div class="alert alert-info text-center" role="alert">
                        <i class="ri-information-line"></i>
                        This page doesn't have any content yet.
                    </div>
                {% endif %}
            </div>
        {% endif %}
    </div>

    {# Hero Section #}
    <section class="bg-body py-5">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6 mb-5 mb-lg-0">
                    <div class="d-flex flex-row align-items-center gap-3 mb-3">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="var(--bs-primary)" viewBox="0 0 16 16">
                            <path d="M12.17 9.53c2.307-2.592 3.278-4.684 3.641-6.218.21-.887.214-1.58.16-2.065a3.6 3.6 0 0 0-.108-.563 2 2 0 0 0-.078-.23V.453c-.073-.164-.168-.234-.352-.295a2 2 0 0 0-.16-.045 4 4 0 0 0-.57-.093c-.49-.044-1.19-.03-2.08.188-1.536.374-3.618 1.343-6.161 3.604l-2.4.238h-.006a2.55 2.55 0 0 0-1.524.734L.15 7.17a.512.512 0 0 0 .433.868l1.896-.271c.28-.04.592.013.955.132.232.076.437.16.655.248l.203.083c.196.816.66 1.58 1.275 2.195.613.614 1.376 1.08 2.191 1.277l.082.202c.089.218.173.424.249.657.118.363.172.676.132.956l-.271 1.9a.512.512 0 0 0 .867.433l2.382-2.386c.41-.41.668-.949.732-1.526zm.11-3.699c-.797.8-1.93.961-2.528.362-.598-.6-.436-1.733.361-2.532.798-.799 1.93-.96 2.528-.361s.437 1.732-.36 2.531Z"></path>
                            <path d="M5.205 10.787a7.6 7.6 0 0 0 1.804 1.352c-1.118 1.007-4.929 2.028-5.054 1.903-.126-.127.737-4.189 1.839-5.18.346.69.837 1.35 1.411 1.925"></path>
                        </svg>
                        <h1 class="fw-medium fs-5 mb-0">ROI-driven Digital Marketing Company</h1>
                    </div>
                    <h2 class="display-6 fw-medium mb-3">Where Digital Excellence Meets Business Success</h2>
                    <p class="fs-4 text-muted mb-3">
                        Partner with <span class="text-primary">Astero Digital</span> for expert digital services that bring you paying customers.
                    </p>
                    <ul class="list-unstyled text-muted fs-5 mb-4">
                        <li>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="var(--bs-primary)" class="me-2" viewBox="0 0 16 16">
                                <path d="M12.736 3.97a.733.733 0 0 1 1.047 0c.286.289.29.756.01 1.05L7.88 12.01a.733.733 0 0 1-1.065.02L3.217 8.384a.757.757 0 0 1 0-1.06.733.733 0 0 1 1.047 0l3.052 3.093 5.4-6.425z"></path>
                            </svg>SEO that actually works
                        </li>
                        <li>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="var(--bs-primary)" class="me-2" viewBox="0 0 16 16">
                                <path d="M12.736 3.97a.733.733 0 0 1 1.047 0c.286.289.29.756.01 1.05L7.88 12.01a.733.733 0 0 1-1.065.02L3.217 8.384a.757.757 0 0 1 0-1.06.733.733 0 0 1 1.047 0l3.052 3.093 5.4-6.425z"></path>
                            </svg>Ads that make money
                        </li>
                        <li>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="var(--bs-primary)" class="me-2" viewBox="0 0 16 16">
                                <path d="M12.736 3.97a.733.733 0 0 1 1.047 0c.286.289.29.756.01 1.05L7.88 12.01a.733.733 0 0 1-1.065.02L3.217 8.384a.757.757 0 0 1 0-1.06.733.733 0 0 1 1.047 0l3.052 3.093 5.4-6.425z"></path>
                            </svg>Websites that sell
                        </li>
                    </ul>
                    {% if theme_option('contact_email') %}
                        <a href="mailto:{{ theme_option('contact_email') }}" class="btn btn-lg btn-yellow text-dark">Book Your Free Strategy Call</a>
                    {% endif %}
                </div>
                <div class="col-lg-5 offset-lg-1">
                    <div class="position-relative">
                        <img src="/storage/media/gdeqpcqjqduazn/team.jpg" alt="Hero Section Image" class="w-100 rounded-4" />
                        <div class="position-absolute text-center bottom-0 start-0" style="margin-left: -24px;">
                            <div class="bg-body rounded-4 shadow-xl p-3" style="width: 160px">
                                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" class="mb-2" fill="var(--bs-green)" viewBox="0 0 16 16">
                                    <path fill-rule="evenodd" d="M0 0h1v15h15v1H0zm14.817 3.113a.5.5 0 0 1 .07.704l-4.5 5.5a.5.5 0 0 1-.74.037L7.06 6.767l-3.656 5.027a.5.5 0 0 1-.808-.588l4-5.5a.5.5 0 0 1 .758-.06l2.609 2.61 4.15-5.073a.5.5 0 0 1 .704-.07"></path>
                                </svg>
                                <div class="fs-4 text-green fw-semibold">+280%</div>
                                <div class="text-muted">Average return on investment</div>
                            </div>
                        </div>
                        <div class="position-absolute text-center top-0 end-0 mt-5" style="margin-right: -24px;">
                            <div class="bg-body rounded-4 shadow-xl p-3" style="width: 160px">
                                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="var(--bs-sky)" class="mb-2" viewBox="0 0 16 16">
                                    <path d="M11 2a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v12h.5a.5.5 0 0 1 0 1H.5a.5.5 0 0 1 0-1H1v-3a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v3h1V7a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v7h1zm1 12h2V2h-2zm-3 0V7H7v7zm-5 0v-3H2v3z"></path>
                                </svg>
                                <div class="fs-4 text-sky fw-semibold">+280%</div>
                                <div class="text-muted">Average return on investment</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {# Blogs Section #}
    <section class="bg-blue-soft py-5">
        <div class="container">
            <div class="text-center">
                <h6 class="h2 fw-medium mb-4">Read our blogs</h6>
            </div>
            <div class="row g-3">
                {% for relatedPost in recentPosts|slice(0, 3) %}
                <div class="col-lg-4">
                    <div class="card card-lift border h-100">
                        <div class="card-body d-flex flex-column gap-3">
                            <div>
                                <h4 class="post-title fw-medium">
                                    <a class="text-body text-decoration-none" href="{{ relatedPost.permalink_url }}">{{ relatedPost.title }}</a>
                                </h4>
                                <div class="mb-2">
                                    <a href="#" class="badge bg-primary-subtle link-primary text-uppercase text-decoration-none">{{ relatedPost.post_category_title }}</a>
                                </div>
                                <p class="post-content text-muted mb-0">
                                    {% if relatedPost.post_excerpt %}
                                        {{ relatedPost.post_excerpt }}
                                    {% else %}
                                        {{ relatedPost.content|striptags|truncate(100) }}
                                    {% endif %}
                                </p>
                            </div>
                            <div class="mt-auto">
                                <a href="{{ relatedPost.permalink_url }}" class="d-flex flex-row align-items-center text-decoration-none gap-2">
                                    <span class="btn btn-sm btn-primary">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="var(--bs-light)" viewBox="0 0 16 16">
                                            <path fill-rule="evenodd" d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708"></path>
                                        </svg>
                                    </span>
                                    <span class="link-primary">Read more</span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </section>
{% endblock %}
