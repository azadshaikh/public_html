{% extends 'layouts/layout.twig' %}

{% block body_class %}search-results{% endblock %}

{% block content %}

    {# Blogs Section #}
    <section class="bg-body py-5">
        <div class="container">
            <header class="search-header mb-5">
                <div class="rounded p-4">
                    <h1 class="display-5 mb-3">Search Results</h1>
                    {% if query is defined and query %}
                        <p class="lead mb-3">Results for: <strong>"{{ query }}"</strong></p>
                    {% endif %}
                </div>
            </header>
            <div class="row">
                <div class="{% if theme_option('show_sidebar_on_archive', true) %}col-lg-8{% else %}col-lg-8 offset-lg-2{% endif %}">

                    {% if posts is defined and posts|length > 0 %}
                        {# Posts Count and Filters #}
                        <div class="archive-meta mb-4">
                            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                                <div class="results-info">
                                    <span class="text-muted">
                                        Showing
                                        {{ posts.firstItem()|default(1) }}-{{ posts.lastItem()|default(posts|length) }} of
                                        {{ posts.total() }} posts
                                    </span>
                                </div>

                                {% if theme_option('show_archive_filters', true) %}
                                    <div class="archive-filters">
                                        <div class="dropdown">
                                            <button class="btn btn-outline-secondary dropdown-toggle btn-sm"
                                                id="sortDropdown" data-bs-toggle="dropdown" type="button">
                                                <i class="ri-filter-line"></i> Sort by
                                            </button>
                                            <ul class="dropdown-menu">
                                                <li><a class="dropdown-item" href="#">Newest First</a></li>
                                                <li><a class="dropdown-item" href="#">Oldest First</a></li>
                                                <li><a class="dropdown-item" href="#">Title A-Z</a></li>
                                            </ul>
                                        </div>
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    {% endif %}

                    {# Posts Grid #}
                    {% if posts is defined and posts|length > 0 %}
                        {% for post in posts %}
                            <article class="post-card card bg-secondary-subtle mb-4 p-0" data-aos="fade-in"
                                data-aos-duration="800">

                                {% if post['featuredImage'] %}
                                    {{ responsive_image(post['featuredImage'].id, {'class': 'card-img-top', 'alt': post['featuredImage'].alt_text|default(post.title), 'style': 'max-height: 400px; object-fit: cover;'}) }}
                                {% else %}
                                    <img class="card-img-top" src="{{ post['featuredImage']_thumbnail_url }}"
                                        alt="{{ post.title }}" style="max-height: 400px; object-fit: cover;" />
                                {% endif %}
                                <div class="card-body p-3">
                                    <div
                                        class="d-flex flex-column flex-sm-row align-items-start align-items-sm-center justify-content-between mb-2">
                                        {% if post['categories'] and post['categories']|length > 0 %}
                                            <div class="post-categories d-flex flex-wrap gap-2">
                                                {% for category in post['categories'] %}
                                                    <span
                                                            class="badge text-body bg-secondary-pale fs-6 mb-sm-0 mb-2">{{ category.title }}</span>
                                                {% endfor %}
                                            </div>
                                        {% endif %}

                                        <span class="d-flex text-muted gap-3">
                                            {% if post['author'] %}
                                                {% set author_base = setting('seo_authors_permalink_base', 'author') %}
                                                <a class="text-decoration-none text-muted"
                                                    href="{{ route('cms.view', [author_base, post['author'].username]) }}">
                                                    <i class="ri-user-line me-1"></i>{{ post['author'].name }}
                                                </a>
                                            {% endif %}
                                            <span><i
                                                    class="ri-calendar-line-event me-1"></i>{{ post.published_date }}</span>
                                            {% set word_count = post.content|striptags|split(' ')|length %}
                                            {% set read_time = ((word_count / 200)|round(0, 'ceil')) %}
                                            {% if read_time < 1 %}{% set read_time = 1 %}{% endif %}
                                            <span><i class="ri-time-line"></i> {{ read_time }} min read</span>
                                        </span>
                                    </div>
                                    <h5 class="card-title fs-4 mb-2">
                                        <a class="text-decoration-none text-body" href="{{ post.permalink_url }}">
                                            {{ post.title }}
                                        </a>
                                    </h5>

                                    {% if post.excerpt %}
                                        <p class="text-muted mb-3">{{ post.excerpt }}</p>
                                    {% else %}
                                        <p class="text-muted mb-3">{{ post.content|striptags|truncate(200) }}</p>
                                    {% endif %}

                                    <a class="text-decoration-none text-body mb-0" href="{{ post.permalink_url }}">
                                        Read more <i class="ri-arrow-right-line"></i>
                                    </a>
                                </div>
                            </article>
                        {% endfor %}
                    {% else %}
                        {# Empty State #}
                        <div class="empty-state py-5 text-center">
                            <div class="mb-4">
                                <i class="ri-search-line display-1 text-muted"></i>
                            </div>
                            <h3 class="text-muted mb-3">No Posts Found</h3>
                            {% if query is defined and query %}
                                <p class="text-muted mb-4">Sorry, no results found for
                                    "<strong>{{ query }}</strong>". Try different keywords.</p>
                            {% else %}
                                <p class="text-muted mb-4">Enter a search term to find content.</p>
                            {% endif %}

                            <div class="search-suggestions">
                                <h6>Search suggestions:</h6>
                                <ul class="list-inline">
                                    <li class="list-inline-item"><a class="badge bg-light text-dark text-decoration-none"
                                            href="{{ route('search', {'q': 'laravel'}) }}">Laravel</a></li>
                                    <li class="list-inline-item"><a class="badge bg-light text-dark text-decoration-none"
                                            href="{{ route('search', {'q': 'technology'}) }}">Technology</a></li>
                                    <li class="list-inline-item"><a class="badge bg-light text-dark text-decoration-none"
                                            href="{{ route('search', {'q': 'tutorial'}) }}">Tutorial</a></li>
                                </ul>
                            </div>
                        </div>
                    {% endif %}

                    {# Pagination #}
                    {% if posts is defined and posts.hasMorePages() %}
                        <nav class="d-flex justify-content-center mt-5" aria-label="Pagination">
                            <div class="d-flex justify-content-center">
                                {% include 'layouts/partials/pagination.twig' with {'paginator': posts} %}
                            </div>
                        </nav>
                    {% endif %}
                </div>

                {% if theme_option('show_sidebar_on_archive', true) %}
                    <div class="col-lg-4 col-md-12">
                        {% include 'layouts/partials/sidebar.twig' %}
                    </div>
                {% endif %}
            </div>
        </div>
    </section>
{% endblock %}

