{% extends 'layouts/layout.twig' %}

{% block body_class %}single-post{% endblock %}

{% block content %}

    {% if session('success') or session('error') %}
        {# Display form submission response here if form is submitted and session is set #}
        {{ form_response() }}
    {% endif %}

    {# Post Content #}
    <section class="bg-body py-5">
        <div class="container">
            <div class="row">
                <div class="{% if theme_option('show_sidebar_on_posts', true) %}col-lg-9{% else %}col-lg-8 offset-lg-2{% endif %}">
                    <article class="single-post">
                        {# Blog Heading, Category, and Date #}
                        <header class="post-header mb-4">
                            {% if theme_option('show_post_categories', true) %}
                                <div class="post-categories d-flex mb-2 flex-wrap gap-2">
                                    {% if post['categories'] and post['categories']|length > 0 %}
                                        {% for category in post['categories'] %}
                                            {% if category %}
                                                <a class="badge text-body bg-secondary-pale fs-6 text-decoration-none"
                                                    href="{{ category.permalink_url }}">{{ category.title }}</a>
                                            {% endif %}
                                        {% endfor %}
                                    {% endif %}
                                </div>
                            {% endif %}
                            <h1 class="mb-2">{{ post.title }}</h1>
                            <div class="post-meta mb-3">
                                <div class="d-flex text-muted small flex-wrap gap-3">
                                    <span><i class="ri-calendar-line-event"></i> {{ post.published_date }}</span>
                                    {% set word_count = post.content|striptags|split(' ')|length %}
                                    {% set read_time = ((word_count / 200)|round(0, 'ceil')) %}
                                    {% if read_time < 1 %}{% set read_time = 1 %}{% endif %}
                                    <span><i class="ri-time-line"></i> {{ read_time }} min read</span>
                                    {% if post.updated_at != post.created_at %}
                                        <span><i class="ri-time-line"></i> Updated {{ post.updated_at|time_ago }}</span>
                                    {% endif %}
                                </div>
                            </div>
                        </header>

                        {# Cover Image #}
                        {% if post['featuredImage'] %}
                            <div class="featured-image mb-4">
                                {{ responsive_image(post['featuredImage'].id, {'class': 'img-fluid rounded', 'alt': post['featuredImage'].alt_text|default(post.title)}) }}
                            </div>
                        {% endif %}

                        {# Blog Content #}
                        <div class="post-content mb-4" data-astero-enabled>
                            {% if post.content %}
                                {{ post.content|raw }}
                            {% else %}
                                <div class="alert alert-info text-center" role="alert">
                                    <i class="ri-information-line"></i>
                                    This post doesn't have any content yet.
                                </div>
                            {% endif %}
                        </div>

                        {# Post Footer #}
                        <footer class="post-footer mt-4 pt-2">
                            {% if theme_option('show_post_tags', false) %}
                                <div class="post-tags mb-4">
                                    <h6 class="mb-2">Tags:</h6>
                                    {% if post['tags'] and post['tags']|length > 0 %}
                                        {% for tag in post['tags'] %}
                                            {% if tag %}
                                                <a class="badge text-bg-secondary text-decoration-none me-2"
                                                    href="{{ tag.permalink_url }}">{{ tag.title }}</a>
                                            {% endif %}
                                        {% endfor %}
                                    {% endif %}
                                </div>
                            {% endif %}

                            {% if theme_option('show_social_sharing', true) %}
                                {# Share Button #}
                                <div class="mb-4">
                                    <button class="btn btn-lg btn-outline-primary" data-bs-toggle="modal"
                                        data-bs-target="#shareModal" type="button" title="Share this post">
                                        <i class="ri-share-line-fill me-1"></i>Share this post
                                    </button>
                                </div>
                            {% endif %}

                            {# Author Section #}
                            {% if post['author'] %}
                                <div class="d-flex align-items-center border-top justify-content-between mb-5 pt-4">
                                    <div class="d-flex align-items-center">
                                        <img class="rounded-circle me-3" src="{{ post['author'].avatar_image }}"
                                            alt="Author Image" width="64" height="64" />
                                        <div>
                                            {% set author_base = setting('seo_authors_permalink_base', 'author') %}
                                            <h6 class="fs-5 mb-1">
                                                <a class="text-decoration-none text-body"
                                                    href="{{ route('cms.view', [author_base, post['author'].username]) }}">{{ post['author'].name }}</a>
                                            </h6>
                                            {% if post['author'].bio %}
                                                <p class="text-muted mb-0">{{ post['author'].bio }}</p>
                                            {% endif %}

                                            {% if post['author'].website_url or post['author'].twitter_url or post['author'].facebook_url or post['author'].instagram_url or post['author'].linkedin_url %}
                                                <div class="social-links d-flex mt-2 gap-2">
                                                    {% if post['author'].website_url %}
                                                        <a class="text-decoration-none text-muted"
                                                            href="{{ post['author'].website_url }}" target="_blank">
                                                            <i class="ri-global-line text-primary"></i>
                                                        </a>
                                                    {% endif %}
                                                    {% if post['author'].twitter_url %}
                                                        <a class="text-decoration-none text-muted"
                                                            href="{{ post['author'].twitter_url }}" target="_blank">
                                                            <i class="ri-twitter-x-line text-dark"></i>
                                                        </a>
                                                    {% endif %}
                                                    {% if post['author'].facebook_url %}
                                                        <a class="text-decoration-none text-muted"
                                                            href="{{ post['author'].facebook_url }}" target="_blank">
                                                            <i class="ri-facebook-line text-blue"></i>
                                                        </a>
                                                    {% endif %}
                                                    {% if post['author'].instagram_url %}
                                                        <a class="text-decoration-none text-muted"
                                                            href="{{ post['author'].instagram_url }}" target="_blank">
                                                            <i class="ri-instagram-line text-pink"></i>
                                                        </a>
                                                    {% endif %}
                                                    {% if post['author'].linkedin_url %}
                                                        <a class="text-decoration-none text-muted"
                                                            href="{{ post['author'].linkedin_url }}" target="_blank">
                                                            <i class="ri-linkedin-line text-blue"></i>
                                                        </a>
                                                    {% endif %}
                                                </div>
                                            {% endif %}
                                        </div>
                                    </div>
                                    <a class="btn btn-outline-primary"
                                        href="{{ route('cms.view', [author_base, post['author'].username]) }}">
                                        View all posts</a>
                                </div>
                            {% endif %}
                        </footer>

                    </article>

                    {# Related Posts #}
                    {% if theme_option('show_related_posts', true) and recentPosts is defined and recentPosts|length > 0 %}
                        <div class="mb-4">
                            <h4 class="mb-4">Similar Posts</h4>
                            <div class="row g-4">
                                {% for relatedPost in recentPosts|slice(0, 2) %}
                                    <div class="col-md-6">
                                        <div class="card bg-secondary-subtle h-100 p-0">
                                            <img class="card-img-top"
                                                src="{{ relatedPost.featured_image_thumbnail_url }}"
                                                alt="{{ relatedPost.title }}"
                                                style="max-height: 150px; object-fit: cover" />
                                            <div class="card-body p-3">
                                                <a class="text-decoration-none text-body"
                                                    href="{{ relatedPost.permalink_url }}">
                                                    <h5 class="card-title">{{ relatedPost.title }}</h5>
                                                </a>
                                                <p class="card-text text-muted mb-2">
                                                    {% if relatedPost.post_excerpt %}
                                                        {{ relatedPost.post_excerpt }}
                                                    {% else %}
                                                        {{ relatedPost.content|striptags|truncate(100) }}
                                                    {% endif %}
                                                </p>
                                                <a class="btn btn-link text-body p-0"
                                                    href="{{ relatedPost.permalink_url }}">Read more</a>
                                            </div>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    {% endif %}
                </div>

                {% if theme_option('show_sidebar_on_posts', true) %}
                    <div class="col-lg-3">
                        {% include 'layouts/partials/sidebar.twig' %}
                    </div>
                {% endif %}
            </div>
        </div>
    </section>

    {% if theme_option('show_social_sharing', true) %}
        {# Share Modal #}
        <div class="modal fade" id="shareModal" aria-labelledby="shareModalLabel" aria-hidden="true" tabindex="-1">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow-none">
                    <div class="modal-header border-0 pb-2">
                        <h5 class="modal-title" id="shareModalLabel"> <i class="ri-share-line-fill me-1"></i> Share this post
                        </h5>
                        <button class="btn-close" data-bs-dismiss="modal" type="button" aria-label="Close"></button>
                    </div>
                    <div class="modal-body pt-0">
                        <div class="d-flex gap-2">
                            {% set post_url = post.permalink_url %}
                            {% set encoded_url = post_url|url_encode %}
                            {% set encoded_title = post.title|url_encode %}
                            <a class="btn btn-outline-primary btn-sm"
                                href="https://twitter.com/intent/tweet?url={{ encoded_url }}&text={{ encoded_title }}"
                                target="_blank">
                                <i class="ri-twitter-x-line"></i> Twitter
                            </a>
                            <a class="btn btn-outline-primary btn-sm"
                                href="https://www.facebook.com/sharer/sharer.php?u={{ encoded_url }}"
                                target="_blank">
                                <i class="ri-facebook-line"></i> Facebook
                            </a>
                            <a class="btn btn-outline-primary btn-sm"
                                href="https://www.linkedin.com/sharing/share-offsite/?url={{ encoded_url }}"
                                target="_blank">
                                <i class="ri-linkedin-line"></i> LinkedIn
                            </a>
                            <button class="btn btn-outline-secondary btn-sm"
                                onclick="copyToClipboard(window.location.href)">
                                <i class="ri-link"></i> Copy Link
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    {% endif %}

{% endblock %}

{# Page builder CSS/JS are auto-injected by ThemeService #}

{% block scripts %}
    <script>
        function copyToClipboard(text) {
            navigator.clipboard.writeText(text).then(function() {
                // Show success message
                const btn = event.target.closest('button');
                const originalText = btn.innerHTML;
                btn.innerHTML = '<i class="ri-check-line2"></i> Copied!';
                btn.classList.add('btn-success');
                btn.classList.remove('btn-outline-secondary');

                setTimeout(() => {
                    btn.innerHTML = originalText;
                    btn.classList.remove('btn-success');
                    btn.classList.add('btn-outline-secondary');
                }, 2000);
            });
        }
    </script>
{% endblock %}
