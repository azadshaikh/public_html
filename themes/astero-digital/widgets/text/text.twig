{% set textClass = 'widget-text' %}
{% set textAlignment = settings.text_alignment|default('left') %}
{% set backgroundEnabled = settings.background_enabled|default(false) %}
{% set backgroundColor = settings.background_color|default('#f8f9fa') %}

<style>
    /* Text Widget Inline Styles */
    .widget-text {
        --text-transition: all 0.3s ease;
    }

    .widget-text .text-content {
        line-height: 1.6;
        word-wrap: break-word;
    }

    .widget-text .text-content.with-background {
        padding: 1.25rem;
        border-radius: 0.5rem;
        border: 1px solid rgba(0, 0, 0, 0.1);
    }

    .widget-text .text-content.align-left { text-align: left; }
    .widget-text .text-content.align-center { text-align: center; }
    .widget-text .text-content.align-right { text-align: right; }
    .widget-text .text-content.align-justify { text-align: justify; }

    .widget-text .text-content p { margin-bottom: 1rem; }
    .widget-text .text-content p:last-child { margin-bottom: 0; }

    .widget-text .text-content h1,
    .widget-text .text-content h2,
    .widget-text .text-content h3,
    .widget-text .text-content h4,
    .widget-text .text-content h5,
    .widget-text .text-content h6 {
        margin-bottom: 0.75rem;
        line-height: 1.3;
    }

    .widget-text .text-content ul,
    .widget-text .text-content ol {
        margin-bottom: 1rem;
        padding-left: 1.5rem;
    }

    .widget-text .text-content blockquote {
        border-left: 4px solid #007bff;
        padding-left: 1rem;
        margin: 1rem 0;
        font-style: italic;
        color: #6c757d;
    }

    .widget-text .text-content img {
        max-width: 100%;
        height: auto;
        border-radius: 0.375rem;
    }

    .widget-text .text-content a {
        color: #007bff;
        text-decoration: none;
        transition: var(--text-transition);
    }

    .widget-text .text-content a:hover {
        color: #0056b3;
        text-decoration: underline;
    }
</style>

<div class="widget {{ textClass }} mb-4">
    {% if title %}
        <h3 class="widget-title mb-3">{{ title }}</h3>
    {% endif %}

    <div class="text-content align-{{ textAlignment }} {% if backgroundEnabled %}with-background{% endif %}"
        {% if backgroundEnabled %}style="background-color: {{ backgroundColor }};"{% endif %}>
        {{ settings.content|default('Add your text content here...')|raw }}
    </div>
</div>

