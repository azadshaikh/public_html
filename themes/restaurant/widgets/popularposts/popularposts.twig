{% set icon = settings.icon|default('') %}
{% set limit = settings.posts_limit|default(3) %}
{% set backgroundStyle = settings.background_style|default('secondary') %}
{% set popularPosts = get_popular_posts('post', limit) %}

{% if popularPosts|length > 0 %}
    {# Popular Posts Card #}
    <div class="card bg-{{ backgroundStyle }}-subtle widget widget-popular-posts mb-4 p-3">
        <div class="card-body">
            {% if title %}
                <h3 class="card-title mb-3">
                    {% if icon %}<i class="{{ icon }} me-2"></i>{% endif %}
                    {{ title }}
                </h3>
            {% endif %}
            <ul class="list-group list-group-flush">
                {% for post in popularPosts %}
                    <li class="list-group-item bg-{{ backgroundStyle }}-subtle px-0">
                        <a class="text-body text-decoration-none fw-semibold d-block mb-1"
                            href="{{ post.permalink_url }}">
                            {{ post.title }}
                        </a>
                        <p class="mb-2">
                            {{ post.published_date }} • <span
                                class="badge text-body bg-secondary-pale fs-6">{{ post.post_category_title }}</span>
                        </p>
                    </li>
                {% endfor %}
            </ul>
        </div>
    </div>
{% endif %}

