{# SaaS CTA Section #}

{% set headline = headline|default('Ready to transform your content strategy?') %}
{% set description = description|default('Join 10,000+ teams already using our platform. Start your free 14-day trial today.') %}
{% set button_text = button_text|default('Get Started Free') %}
{% set button_url = button_url|default('/signup') %}
{% set secondary_text = secondary_text|default('No credit card required') %}

<section class="saas-cta py-6 py-lg-7 position-relative overflow-hidden" title="CTA">
    {# Background #}
    <div class="cta-bg position-absolute top-0 start-0 w-100 h-100" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); z-index: -2;"></div>
    
    {# Decorative Elements #}
    <div class="cta-shape cta-shape-1 position-absolute rounded-circle" style="width: 400px; height: 400px; background: rgba(255,255,255,0.05); top: -100px; left: -100px; z-index: -1;"></div>
    <div class="cta-shape cta-shape-2 position-absolute rounded-circle" style="width: 300px; height: 300px; background: rgba(255,255,255,0.03); bottom: -50px; right: -50px; z-index: -1;"></div>
    
    <div class="container position-relative">
        <div class="row justify-content-center text-center">
            <div class="col-lg-8" data-aos="fade-up">
                {# Badge #}
                <span class="badge bg-white bg-opacity-20 text-white px-3 py-2 mb-3">
                    <i class="ri-rocket-line me-1"></i>Get Started Today
                </span>
                
                {# Headline #}
                <h2 class="display-4 fw-bold text-white mb-3">{{ headline }}</h2>
                
                {# Description #}
                <p class="lead text-white opacity-75 mb-4">{{ description }}</p>
                
                {# CTA Button #}
                <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center align-items-center">
                    <a href="{{ button_url }}" class="btn btn-light btn-lg px-5 py-3 rounded-pill fw-semibold">
                        {{ button_text }}
                        <i class="ri-arrow-right-line ms-2"></i>
                    </a>
                </div>
                
                {# Secondary Text #}
                <p class="text-white opacity-75 mt-3 mb-0 small">
                    <i class="ri-shield-check-line me-1"></i>{{ secondary_text }}
                </p>
            </div>
        </div>
    </div>
</section>

<style>
.saas-cta {
    position: relative;
}
.cta-shape {
    animation: pulse-slow 4s ease-in-out infinite;
}
@keyframes pulse-slow {
    0%, 100% { transform: scale(1); opacity: 0.05; }
    50% { transform: scale(1.1); opacity: 0.08; }
}
.py-6 {
    padding-top: 5rem;
    padding-bottom: 5rem;
}
</style>
