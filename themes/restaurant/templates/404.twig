{% extends 'layouts/layout.twig' %}
{% block body_class %}error-404 not-found{% endblock %}

{% block content %}
    <div class="container d-flex align-items-center justify-content-center" style="min-height: calc(100vh - 300px);">
        <div class="row">
            <div class="col-12 text-center">
                <h1 class="display-1 text-primary fw-bold mb-3">404</h1>
                <h2 class="h3 mb-3">Page Not Found</h2>
                <p class="lead text-muted mb-4">
                    Sorry, the page you are looking for could not be found.
                </p>
                <a href="{{ urls.home }}" class="btn btn-primary btn-lg rounded-pill px-4">
                    Go Home
                </a>
            </div>
        </div>
    </div>
{% endblock %}

