<aside>
    {# Widget Area: Main Sidebar #}
    {% if has_widgets('sidebar-main') %}
        {{ render_widget_area('sidebar-main') }}
    {% else %}
        {# Fallback content when no widgets are configured #}
        <div class="card mb-4">
            <div class="card-body">
                <h5 class="card-title">Welcome</h5>
                <p class="card-text">This is the main sidebar widget area. Configure widgets in the admin panel to
                    customize this area.</p>
            </div>
        </div>
    {% endif %}
</aside>
