{% set icon = settings.icon|default('') %}
{% set limit = settings.categories_limit|default(3) %}
{% set backgroundStyle = settings.background_style|default('secondary') %}
{% set categories = get_categories('category', limit) %}

{% if categories|length > 0 %}
    {# Categories Card #}
    <div class="card bg-{{ backgroundStyle }}-subtle widget widget-categories mb-4 p-3">
        <div class="card-body">
            {% if title %}
                <h3 class="card-title mb-3">
                    {% if icon %}<i class="{{ icon }} me-2"></i>{% endif %}
                    {{ title }}
                </h3>
            {% endif %}
            <ul class="list-unstyled mb-0">
                {% for category in categories %}
                    <li class="mb-2">
                        <a class="text-decoration-none text-body d-flex justify-content-between"
                            href="{{ category.permalink_url }}">
                            {{ category.title }} <span class="text-muted">({{ category.post_count|default(0) }})</span>
                        </a>
                    </li>
                {% endfor %}
            </ul>
        </div>
    </div>
{% endif %}

