{% set icon = settings.icon|default('') %}
{% set backgroundStyle = settings.background_style|default('secondary') %}
{% set title = settings.title|default('') %}
{% set placeholder_text = settings.placeholder_text|default('Search topics, titles...') %}

{# Search Card #}
<div class="card bg-secondary-subtle mb-4 p-3">
    <div class="card-body">
        {% if title %}
            <h3 class="card-title mb-3">
                {% if icon %}<i class="{{ icon }} me-2"></i>{% endif %}
                {{ title }}
            </h3>
        {% endif %}
        <form class="search-form" method="GET" action="{{ url('/search.html') }}">
            <div class="mb-3">
                <input class="form-control form-control-lg" name="q" type="text" value="{{ old('q') }}"
                    placeholder="{{ placeholder_text }}" />
            </div>
            <button class="btn btn-lg btn-primary w-100" type="submit">Search</button>
        </form>
    </div>
</div>

