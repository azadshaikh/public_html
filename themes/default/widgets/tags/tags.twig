{% set icon = settings.icon|default('') %}
{% set limit = settings.tags_limit|default(3) %}
{% set backgroundStyle = settings.background_style|default('secondary') %}
{% set tags = get_tags('tag', limit) %}

{% if tags|length > 0 %}
    <div class="card bg-{{ backgroundStyle }}-subtle widget widget-tags mb-4 p-3">
        <div class="card-body">
            {% if title %}
                <h3 class="card-title mb-3">
                    {% if icon %}<i class="{{ icon }} me-2"></i>{% endif %}
                    {{ title }}
                </h3>
            {% endif %}
            <div class="d-flex flex-wrap gap-2">
                {% for tag in tags %}
                    <a class="badge text-body bg-secondary-pale fs-6 text-decoration-none"
                        href="{{ tag.permalink_url }}">
                        {{ tag.title }}
                    </a>
                {% endfor %}
            </div>
        </div>
    </div>
{% endif %}
